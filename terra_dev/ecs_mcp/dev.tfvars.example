environment  = "dev"
project_name = "ecs-mcp"

# 公開アクセス元。
# 学習用に全開放しているが、実運用では必ず絞ること。
allowed_cidrs = ["0.0.0.0/0"]

# HTTPS / DNS 関連
app_domain_name       = "mcp-dev.example.com"
create_route53_record = false
route53_zone_id       = ""
acm_certificate_arn   = "arn:aws:acm:ap-northeast-1:123456789012:certificate/replace-me"

# コンテナサイズ
container_port   = 8000
container_cpu    = 256
container_memory = 512

# 初回 apply では 0 のままにして、ECR push 後に 1 へ上げると安全。
desired_count = 0
image_tag     = "latest"

enable_server_oauth = true

# AWS 管理 Keycloak 設定
deploy_keycloak_on_aws   = true
keycloak_path            = "/keycloak"
keycloak_realm           = "mcp"
keycloak_admin_username  = "admin"
keycloak_admin_password  = "REPLACE_ME_KEYCLOAK_ADMIN_PASSWORD"
keycloak_db_password     = "REPLACE_ME_KEYCLOAK_DB_PASSWORD"

# Keycloak realm / client は初回起動後に Admin Console で作成する
keycloak_public_client_id            = "claude-desktop"
keycloak_introspection_client_id     = "mcp-resource-server"
keycloak_introspection_client_secret = "REPLACE_ME"

# 外部 Keycloak を使う場合のみ指定する
# keycloak_base_url = "https://keycloak.example.com"

keycloak_enable_dynamic_client_registration = false

oauth_supported_scopes = ["mcp:tools"]
oauth_required_scopes  = ["mcp:tools"]
